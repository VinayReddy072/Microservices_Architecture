# ============================================================
# .gitignore for University Lab Equipment Platform
# ============================================================

# Maven
target/
*.class
*.jar
*.war
*.ear
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo

# Environment secrets (NEVER commit!)
.env
*.env.local
*.env.production

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# Spring Boot devtools
.spring-boot-devtools.properties
