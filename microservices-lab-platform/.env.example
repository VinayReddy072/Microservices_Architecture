# Environment Variables for Local Development
# Copy this file to .env and fill in production values
# NEVER commit .env to source control

# ============ Config Server ============
CONFIG_SERVER_USERNAME=configuser
CONFIG_SERVER_PASSWORD=configpass

# ============ Eureka ============
EUREKA_USERNAME=eurekauser
EUREKA_PASSWORD=eurekapass

# ============ JWT (CHANGE IN PRODUCTION — must be >= 256 bits) ============
JWT_SECRET=dev-secret-key-must-be-at-least-256-bits-long-for-HS256-algorithm

# ============ Databases ============
BOOKING_DB_USERNAME=bookinguser
BOOKING_DB_PASSWORD=bookingpass

EQUIPMENT_DB_USERNAME=equipmentuser
EQUIPMENT_DB_PASSWORD=equipmentpass

# ============ RabbitMQ ============
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ============ Spring Profile ============
SPRING_PROFILES_ACTIVE=dev
